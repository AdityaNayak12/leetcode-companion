{
    "manifest_version": 3,
    "name": "LeetCode Testcase Playground",
    "version": "1.0.0",
    "description": "Generate AI-powered testcases and add custom testcases for LeetCode problems.",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://api.groq.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://leetcode.com/problems/*"
            ],
            "js": [
                "config.js",
                "storage.js",
                "groq.js",
                "panel.js",
                "content.js"
            ],
            "css": [
                "panel.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}